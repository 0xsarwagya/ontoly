{
  "name": "@0xsarwagya/ontoly-intelligence",
  "version": "1.0.0-rc.5",
  "description": "Deterministic intelligence APIs over Ontoly Software Graph, Semantic Index, and Semantics artifacts.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xsarwagya/ontoly.git",
    "directory": "packages/intelligence"
  },
  "homepage": "https://oss.sarwagya.wtf/ontoly",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json",
    "check-types": "tsc --noEmit",
    "test": "cd ../.. && vitest run packages/intelligence/tests"
  },
  "dependencies": {
    "@0xsarwagya/ontoly-core": "workspace:*",
    "@0xsarwagya/ontoly-enhancer-history": "workspace:*",
    "@0xsarwagya/ontoly-enhancer-semantics": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsup": "^8.3.5",
    "typescript": "7.0.2",
    "vitest": "^4.1.10"
  },
  "bugs": {
    "url": "https://github.com/0xsarwagya/ontoly/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/0xsarwagya"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "keywords": [
    "ontoly",
    "software-graph",
    "semantic-intelligence",
    "evidence",
    "query-expansion",
    "developer-tools"
  ]
}
