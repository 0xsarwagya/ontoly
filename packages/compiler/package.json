{
  "name": "@0xsarwagya/ontoly-compiler",
  "version": "1.0.0-rc.1",
  "description": "Repository discovery, graph build pipeline, and watch mode for Ontoly.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xsarwagya/ontoly.git",
    "directory": "packages/compiler"
  },
  "homepage": "https://oss.sarwagya.wtf/ontoly",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json",
    "check-types": "tsc --noEmit",
    "test": "vitest run tests"
  },
  "dependencies": {
    "@0xsarwagya/ontoly-cache": "workspace:*",
    "@0xsarwagya/ontoly-core": "workspace:*",
    "@0xsarwagya/ontoly-diagnostics": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsup": "^8.3.5",
    "typescript": "7.0.2",
    "vitest": "^4.1.10"
  },
  "bugs": {
    "url": "https://github.com/0xsarwagya/ontoly/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/0xsarwagya"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "keywords": [
    "ontoly",
    "software-graph",
    "typescript",
    "static-analysis",
    "developer-tools",
    "compiler",
    "pipeline"
  ]
}
