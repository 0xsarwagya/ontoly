{
  "name": "@0xsarwagya/ontoly-cli",
  "version": "0.1.0-alpha.17",
  "description": "CLI and public convenience API for Ontoly.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xsarwagya/ontoly.git",
    "directory": "packages/cli"
  },
  "homepage": "https://ontoly.sarwagya.wtf",
  "keywords": [
    "ontoly",
    "software-graph",
    "typescript",
    "static-analysis",
    "developer-tools",
    "cli",
    "mcp",
    "validation"
  ],
  "sideEffects": false,
  "bin": {
    "ontoly": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json",
    "check-types": "tsc --noEmit",
    "test": "cd ../.. && vitest run packages/cli/tests"
  },
  "dependencies": {
    "@0xsarwagya/ontoly-analyzers": "workspace:*",
    "@0xsarwagya/ontoly-cache": "workspace:*",
    "@0xsarwagya/ontoly-capabilities": "workspace:*",
    "@0xsarwagya/ontoly-compiler": "workspace:*",
    "@0xsarwagya/ontoly-core": "workspace:*",
    "@0xsarwagya/ontoly-enhancer": "workspace:*",
    "@0xsarwagya/ontoly-mcp": "workspace:*",
    "@0xsarwagya/ontoly-parser-openapi": "workspace:*",
    "@0xsarwagya/ontoly-parser-typescript": "workspace:*",
    "@0xsarwagya/ontoly-plugin-html": "workspace:*",
    "@0xsarwagya/ontoly-query": "workspace:*",
    "@0xsarwagya/ontoly-semantic": "workspace:*",
    "@0xsarwagya/ontoly-typescript": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsup": "^8.3.5",
    "typescript": "5.9.2",
    "vitest": "^3.0.0"
  },
  "bugs": {
    "url": "https://github.com/0xsarwagya/ontoly/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/0xsarwagya"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts"
}
